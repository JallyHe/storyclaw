{
  "name": "storyclaw",
  "version": "0.1.7",
  "description": "AI-powered screenplay editor",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "build": {
    "appId": "com.storyclaw.app",
    "productName": "StoryClaw",
    "artifactName": "StoryClaw-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/assets/storyclaw-logo.png",
        "to": "assets/storyclaw-logo.png"
      },
      {
        "from": "electron/agent/skills",
        "to": "skills"
      },
      {
        "from": "electron/agent/agents",
        "to": "agents"
      },
      {
        "from": "electron/agent/agent-skills.json",
        "to": "agent-skills.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JallyHe",
        "repo": "storyclaw"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/storyclaw-logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/storyclaw-logo.png"
    }
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "dingtalk-stream": "^2.1.6-beta.1",
    "docx": "^9.7.1",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "mammoth": "^1.12.0",
    "path-browserify": "^1.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "5.4.296",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.7",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "react-pdf": "^10.4.1",
    "undici": "^8.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.14.0",
    "@types/path-browserify": "^1.0.3",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "jsdom": "^24.1.0",
    "marked": "^18.0.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
